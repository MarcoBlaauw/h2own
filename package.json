{
  "name": "h2own-monorepo",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n api,web,storybook -c cyan,green,magenta \"pnpm -C api dev\" \"pnpm -C web dev\" \"pnpm -C web storybook\"",
    "hooks:install": "git config core.hooksPath .githooks",
    "lint": "pnpm --filter h2own-api lint && pnpm --filter h2own-web lint",
    "check": "pnpm --filter h2own-web check",
    "secrets:scan": "./scripts/scan-secrets.sh",
    "format": "pnpm --filter h2own-api format && pnpm --filter h2own-web format",
    "format:check": "pnpm --filter h2own-api format:check && pnpm --filter h2own-web format:check",
    "test": "pnpm --filter h2own-api test",
    "test:web": "pnpm --filter h2own-web test",
    "test:cloud": "pnpm lint && pnpm test && pnpm test:web && pnpm check && pnpm audit --prod",
    "test:web:e2e": "pnpm --filter h2own-web test:e2e",
    "test:e2e": "bash ./scripts/test-e2e.sh",
    "test:visual": "pnpm --filter h2own-web test:visual"
  },
  "pnpm": {
    "overrides": {
      "ajv@6.12.6": "6.14.0",
      "esbuild": "0.25.0",
      "js-yaml": "4.1.1",
      "qs": "6.14.2",
      "tar": "7.5.8",
      "cookie": "1.1.1",
      "devalue": "5.6.4",
      "minimatch": "10.2.3",
      "rollup": "4.59.0",
      "undici": "7.24.1",
      "vite@^6.0.0": "6.4.1"
    },
    "packageExtensions": {
      "@storybook/svelte-vite@*": {
        "peerDependencies": {
          "@sveltejs/vite-plugin-svelte": "^2.0.0 || ^3.0.0 || ^4.0.0 || ^5.0.0 || ^6.0.0"
        }
      }
    },
    "onlyBuiltDependencies": [
      "@tailwindcss/oxide",
      "argon2",
      "esbuild",
      "unrs-resolver"
    ]
  },
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be",
  "devDependencies": {
    "argon2": "^0.44.0",
    "concurrently": "^9.2.1",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "postgres": "^3.4.8"
  }
}
