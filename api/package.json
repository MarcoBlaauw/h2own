{
  "name": "h2own-api",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "start": "node dist/app.js",
    "build": "tsc -p tsconfig.json",
    "lint": "eslint .",
    "test": "vitest run",
    "format": "prettier --write src/app.ts src/env.ts src/routes/auth.ts src/services/session-store.ts src/services/session-store.test.ts src/types/fastify.d.ts",
    "format:check": "prettier --check src/app.ts src/env.ts src/routes/auth.ts src/services/session-store.ts src/services/session-store.test.ts src/types/fastify.d.ts",
    "seed": "tsx src/seed.ts",
    "user:create-admin": "tsx ../scripts/create-admin.ts",
    "user:set-password": "tsx ../scripts/set-password.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/redis": "^7.2.0",
    "argon2": "^0.44.0",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.9",
    "drizzle-orm": "^0.45.1",
    "fastify": "^5.8.2",
    "fastify-plugin": "^5.1.0",
    "nodemailer": "^8.0.2",
    "otplib": "^13.3.0",
    "postgres": "^3.4.8",
    "qrcode": "^1.5.4",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.4.0",
    "@types/nodemailer": "^7.0.11",
    "@types/qrcode": "^1.5.6",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@10.32.1"
}
